# Exclude development sources and large folders
src/**
webview-react/**
test/**
.vscode/**
out/**
**/*.log

# Exclude secrets
assets/ollama-blocker/service-account-key.json
ollama-blocker/service-account-key.json

# Keep required runtime assets
!dist/**
!webview/**
!media/**

# Exclude all assets by default, then selectively include needed binaries
assets/**
!assets/ollama-blocker/ollama-blocker-embedded
# Ensure docs and metadata are included
!package.json
!README.md
!README.ko.md
!RELEASE.md
!RELEASE.ko.md
!CHANGELOG.md
!NOTICE.txt
!LICENSE.txt
!supported_ollama_model.json

# Final safeguard: secrets must remain excluded
assets/ollama-blocker/service-account-key.json
ollama-blocker/service-account-key.json
# Exclude development folders and large/unrelated directories
.git/**
.github/**
.vscode/**
node_modules/**
coverage/**
out/**
release/**
mov_gen/**
Wan2.2/**
terminal-daemon/**
ollama-blocker/**

# Exclude sources (we ship bundled dist and webview assets)
src/**
**/*.map

# Keep runtime assets
!dist/**
!webview/**/*.html
!webview/locales/**/*.json
!media/**
# Only allow specific binaries from assets
!assets/terminal-daemon/terminal-client

# Exclude secrets and sensitive files
assets/ollama-blocker/service-account-key.json
**/service-account-key.json
**/*service-account-key*
**/*firebase*
**/*gcp*
**/*google*
