# Exclude development folders and large/unrelated directories
.git/**
.github/**
.vscode/**
node_modules/**
coverage/**
out/**
release/**
mov_gen/**
Wan2.2/**
terminal-daemon/**
ollama-blocker/**

# Exclude sources (we ship bundled dist and webview assets)
src/**
**/*.map

# Keep runtime assets
!dist/**
!webview/**/*.html
!webview/locales/**/*.json
!media/**
!assets/**
!assets/terminal-daemon/terminal-client

# Exclude secrets and sensitive files
assets/ollama-blocker/service-account-key.json
**/service-account-key.json
**/*service-account-key*
**/*firebase*
**/*gcp*
**/*google*
