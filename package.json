{
  "name": "aidevIde",
  "displayName": "aidev-ide",
  "description": "AI-powered development assistant with customizable LLM",
  "version": "6.1.1",
  "publisher": "banya",
  "engines": {
    "vscode": "^1.85.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "This extension can work with untrusted workspaces."
    },
    "virtualWorkspaces": {
      "supported": true,
      "description": "This extension can work with virtual workspaces."
    }
  },
  "enableProposedApi": false,
  "enabledApiProposals": [],
  "activationEvents": [
    "onView:aidevIde.chatView",
    "onCommand:aidevIdeCode.openChatView",
    "onCommand:aidevIdeCode.openSettingsPanel",
    "onCommand:aidevIdeCode.openLicensePanel"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DAIOSFoundation/aidev-ide"
  },
  "categories": [
    "LLM",
    "AI",
    "Chat",
    "Code Editor",
    "VSCode Plugin"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aidevIdeCode",
          "title": "Codepilot",
          "icon": "./media/codepilot.svg"
        }
      ]
    },
    "views": {
      "aidevIdeCode": [
        {
          "id": "aidevIde.chatView",
          "name": " ",
          "type": "webview",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "aidevIdeCode.openSettingsPanel",
        "title": "Setting"
      },
      {
        "command": "aidevIdeCode.openLicensePanel",
        "title": "License"
      },
      {
        "command": "aidevIdeCode.openChatView",
        "title": "Open aidev-ide Chat"
      },
      {
        "command": "aidevIdeCode.startOllamaBlocker",
        "title": "Start Ollama Blocker"
      },
      {
        "command": "aidevIdeCode.stopOllamaBlocker",
        "title": "Stop Ollama Blocker"
      },
      {
        "command": "aidevIdeCode.ollamaBlockerStatus",
        "title": "Ollama Blocker Status"
      },
      {
        "command": "aidevIdeCode.killOllamaProcesses",
        "title": "Kill Ollama Processes"
      },
      {
        "command": "aidevIdeCode.testOllamaBlocker",
        "title": "Test Ollama Blocker (Debug)"
      },
      {
        "command": "aidevIdeCode.testFirebaseConnection",
        "title": "Test Firebase Connection (Debug)"
      },
      {
        "command": "aidevIdeCode.testTerminalMonitoring",
        "title": "Test Terminal Monitoring (Debug)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aidevIdeCode.openSettingsPanel",
          "when": "view == aidevIde.chatView",
          "group": "navigation",
          "order": 1,
          "icon": "$(settings-gear)",
          "title": "Setting"
        },
        {
          "command": "aidevIdeCode.openLicensePanel",
          "when": "view == aidevIde.chatView",
          "group": "navigation",
          "order": 2,
          "icon": "$(law)",
          "title": "License"
        }
      ]
    },
    "configuration": {
      "title": "aidev-ide Configuration",
      "properties": {
        "aidevIde.sourcePaths": {
          "type": "array",
          "default": [],
          "description": "aidev-ide가 AI 응답을 생성할 때 참조할 소스 코드 파일 및 디렉토리 경로 목록을 지정합니다. 여기에 지정된 모든 파일과 폴더의 내용이 AI에게 컨텍스트 정보로 제공될 수 있습니다.",
          "items": {
            "type": "string"
          }
        },
        "aidevIde.apiKey": {
          "type": "string",
          "default": "",
          "description": "AIDEV API Key를 설정합니다. Secret Storage에 안전하게 저장됩니다.",
          "scope": "resource",
          "markdownDescription": "AIDEV API Key를 설정합니다. 이는 VS Code의 Secret Storage에 안전하게 저장되며, 확장이 이 키를 사용하여 Gemini API에 접근합니다. [여기](https://aistudio.google.com/app/apikey)에서 API 키를 얻을 수 있습니다."
        },
        "aidevIde.aiModel": {
          "type": "string",
          "default": "ollama",
          "enum": [
            "gemini",
            "ollama"
          ],
          "description": "사용할 AI 모델 엔진을 선택합니다.",
          "scope": "resource"
        },
        "aidevIde.geminiModel": {
          "type": "string",
          "default": "gemini-3-pro-preview",
          "enum": [
            "gemini-3-pro-preview",
            "gemini-3-flash-preview"
          ],
          "description": "사용할 Gemini 모델을 선택합니다.",
          "scope": "resource"
        },
        "aidevIde.autoUpdateFiles": {
          "type": "boolean",
          "default": false,
          "description": "Enable or disable automatic updating of files based on LLM's code block suggestions. If disabled, you will be prompted before updating.",
          "scope": "resource"
        },
        "aidevIde.projectRoot": {
          "type": "string",
          "default": "",
          "description": "aidev-ide가 프로젝트의 최상위 경로로 인식할 디렉토리를 설정합니다. 이 경로는 파일 경로를 참조할 때 기준점으로 사용될 수 있습니다.",
          "scope": "resource"
        },
        "aidevIde.language": {
          "type": "string",
          "default": "ko",
          "enum": [
            "ko",
            "en",
            "zh",
            "es",
            "de",
            "fr",
            "ja"
          ],
          "description": "aidev-ide UI 언어를 설정합니다. 지원 언어: 한국어(ko), 영어(en), 중국어(zh), 스페인어(es), 독일어(de), 프랑스어(fr), 일본어(ja)",
          "scope": "resource"
        },
        "aidevIde.terminalDaemonEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable terminal-daemon to run commands via external PTY daemon and stream logs/errors.",
          "scope": "resource"
        },
        "aidevIde.outputLogEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable logs displayed in VS Code's OUTPUT panel. Disabling makes it easier to check terminal logs.",
          "scope": "resource"
        },
        "aidevIde.errorRetryCount": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Set the maximum number of automatic correction attempts when errors occur in the terminal. (1-10 times, default: 3 times)",
          "scope": "resource"
        },
        "aidevIde.autoCorrectionEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable automatic terminal error correction.",
          "scope": "resource"
        },
        "aidevIde.autoExecuteCommands": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable automatic execution of bash/powershell/cmd commands from LLM responses.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.22.0",
    "evaluate": "^1.0.2",
    "firebase": "^10.7.0",
    "korean-text-analytics": "^0.0.7",
    "markdown-it-container": "^4.0.0",
    "tree-sitter-wasms": "^0.1.11",
    "web-tree-sitter": "^0.20.8"
  },
  "devDependencies": {
    "@babel/core": "^7.27.3",
    "@babel/preset-env": "^7.27.2",
    "copy-webpack-plugin": "^11.0.0",
    "@google/generative-ai": "^0.16.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.24",
    "@types/vscode": "1.85",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "babel-loader": "^10.0.0",
    "dompurify": "^3.2.6",
    "eslint": "^9.25.1",
    "markdown-it": "^14.1.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  }
}